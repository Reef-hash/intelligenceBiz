NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon-key
REDIS_URL=redis://localhost:6379

# Server-only — same project as NEXT_PUBLIC_SUPABASE_URL above, but read
# separately by server actions (createServiceRoleClient) since
# NEXT_PUBLIC_* vars are only guaranteed inlined into browser-bound code.
SUPABASE_URL=https://your-project.supabase.co

# Used by server actions to bypass RLS for tenant-scoped writes
# (e.g. sending a human reply) — never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=service-role-key
